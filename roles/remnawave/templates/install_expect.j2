#!/usr/bin/expect -f

set timeout {{ remnawave_timeout }}

spawn env TERM=xterm bash /tmp/install_remnawave.sh

# Главное меню
expect "Select action (0-10):"
send "1\r"

# Подменю: только нода
expect "Select action (0-3):"
send "4\r"

# Selfsteal домен
expect "selfsteal domain"
send "{{ node_domain }}\r"

# IP панели
expect "IP address of the panel"
send "{{ panel_ip }}\r"

# Сертификат — два Enter: один после содержимого, второй пустой
expect "press Enter twice"
send "{{ node_certificate | trim }}\r\r"

# Подтверждение сертификата — матчим до (y/n) включительно, чтобы не оставлять
# этот хвост в буфере: иначе большой expect-блок ниже сразу же его подхватит
# и отправит лишний y в следующий промпт
expect -re "correct\?.*\(y/n\)"
send "y\r"

# Дальнейшие промпты опциональны — зависят от состояния системы
# (cert generation пропускается если сертификат уже есть и т.д.)
expect {
    "certificate generation method" { send "2\r";                   exp_continue }
    "your email"                    { send "{{ admin_email }}\r";   exp_continue }
    "(y/n)"                         { send "y\r";                   exp_continue }
    "(y/N)"                         { send "y\r";                   exp_continue }
    "(Y/n)"                         { send "y\r";                   exp_continue }
    "\[y/N\]"                       { send "y\r";                   exp_continue }
    "\[Y/n\]"                       { send "y\r";                   exp_continue }
    "Node successfully launched"    { exit 0 }
    timeout                         { exit 1 }
    eof                             { exit 0 }
}
