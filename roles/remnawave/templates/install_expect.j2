#!/usr/bin/expect -f

set timeout {{ remnawave_timeout }}

spawn env TERM=xterm bash /tmp/install_remnawave.sh

# Главное меню
expect "Select action (0-10):"
send "1\r"

# Подменю: только нода
expect "Select action (0-3):"
send "4\r"

# Selfsteal домен
expect "selfsteal domain"
send "{{ node_domain }}\r"

# IP панели
expect "IP address of the panel"
send "{{ panel_ip }}\r"

# Сертификат (скрипт ждёт два Enter — \n в конце переменной + \r ниже)
expect "press Enter twice"
send "{{ node_certificate }}\r"

# Метод генерации сертификата
expect "certificate generation method"
send "2\r"

# Email
expect "your email"
send "{{ admin_email }}\r"

# Любые y/n подтверждения до конца
expect {
    "(y/n)" { send "y\r"; exp_continue }
    "\[y/N\]" { send "y\r"; exp_continue }
    "\[Y/n\]" { send "y\r"; exp_continue }
    timeout   { exit 1 }
    eof       { exit 0 }
}
